REOS_SECRET_KEY=replace-with-a-long-random-secret
REOS_ENCRYPTION_KEY=replace-with-a-fernet-key
REOS_ADMIN_USER=admin
REOS_ADMIN_PASSWORD=replace-with-a-strong-first-password
REOS_HOST=127.0.0.1
REOS_PORT=5000
REOS_DEBUG=0
REOS_COOKIE_SECURE=0
REOS_ENABLE_HSTS=0
REOS_ALLOWED_HOSTS=localhost,127.0.0.1
REOS_CORS_ORIGINS=
REOS_MAX_CONTENT_LENGTH=104857600
REOS_AUTO_BACKUP_ENABLED=1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Web backups are stored in reos/backups/ and include reos.db plus .reos_encryption_key.
# Automatic backups run once per day while the app is in use.
